    "typedExpected": "2026-06-19T12:00:00Z",
    "currentlyBuggy": true,
    "bugDescription": "emit.go:108 uses Z07:00 format preserving offset. Correct for UTC input but wrong for non-UTC. All paths currently drop sub-second."
  },
  {
    "id": "time-sub-second-500ms",
